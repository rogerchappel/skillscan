{
  "name": "skillscan",
  "version": "0.1.0",
  "description": "Local-first scanner for risky agent instruction files and skill documentation.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "skillscan": "./src/index.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "node --check src/index.js",
    "test": "node --test",
    "smoke": "node src/index.js check docs/PRD.md && node src/index.js json docs/PRD.md",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run build && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-instructions",
    "skills",
    "security",
    "markdown",
    "scanner"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/skillscan.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/skillscan/issues"
  },
  "homepage": "https://github.com/rogerchappel/skillscan#readme"
}
